{
  "//": [
    "VS Code Continue extension config — drop this into ~/.continue/config.json",
    "Replace <LITELLM_MASTER_KEY> with your actual key from .env",
    "",
    "All model names are role-based. Valid roles: router | reasoner | coder | supervisor | embed",
    "Continue docs: https://docs.continue.dev/customize/model-providers/openai",
    "",
    "To get your key:",
    "  grep LITELLM_MASTER_KEY .env | cut -d= -f2"
  ],
  "models": [
    {
      "title": "Coder (local)",
      "provider": "openai",
      "model": "coder",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "<LITELLM_MASTER_KEY>"
    },
    {
      "title": "Reasoner (local)",
      "provider": "openai",
      "model": "reasoner",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "<LITELLM_MASTER_KEY>"
    },
    {
      "title": "Supervisor (local)",
      "provider": "openai",
      "model": "supervisor",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "<LITELLM_MASTER_KEY>"
    },
    {
      "title": "Router — fast (local)",
      "provider": "openai",
      "model": "router",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "<LITELLM_MASTER_KEY>"
    }
  ],
  "tabAutocompleteModel": {
    "title": "Router — autocomplete",
    "provider": "openai",
    "model": "router",
    "apiBase": "http://localhost:4000/v1",
    "apiKey": "<LITELLM_MASTER_KEY>"
  },
  "embeddingsProvider": {
    "provider": "openai",
    "model": "embed",
    "apiBase": "http://localhost:4000/v1",
    "apiKey": "<LITELLM_MASTER_KEY>"
  }
}
