# ailocal environment variables
# Run scripts/install.sh to auto-generate .env with a secure random key.
# Never commit .env to version control.

# ── General ────────────────────────────────────────────────────────────────
AILOCAL_ENV=local

# ── Ollama (runs natively on macOS for Metal/GPU acceleration) ─────────────
# The LiteLLM container reaches the host Ollama daemon via this address.
OLLAMA_URL=http://host.docker.internal:11434

# ── LiteLLM proxy authentication ──────────────────────────────────────────
# The single key every client uses. Send: Authorization: Bearer <LITELLM_MASTER_KEY>
# For Claude Code / Codex: set ANTHROPIC_API_KEY / OPENAI_API_KEY to this value
# and point the base URL at http://localhost:4000
LITELLM_MASTER_KEY=

# ── Cloud fallbacks (disabled by default) ─────────────────────────────────
# Set ENABLE_CLOUD=true and uncomment the relevant model block in
# config/litellm/config.yaml to allow fallback to a cloud model.
ENABLE_CLOUD=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
