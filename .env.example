# ailocal environment variables
# Run scripts/install.sh to auto-generate .env with secure random secrets.
# Never commit .env to version control.

# ── General ────────────────────────────────────────────────────────────────
AILOCAL_ENV=local
HOST_HTTP_PORT=8080
HOST_PROMETHEUS_PORT=9090
HOST_GRAFANA_PORT=3000

# ── Ollama (runs natively on macOS for Metal/GPU acceleration) ─────────────
# Docker containers reach the host Ollama daemon via this address.
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_QUANTIZATION=q4_K_M

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
POSTGRES_USER=ailocal
POSTGRES_PASSWORD=
POSTGRES_DB=ailocal

# ── Cache (Redis) ──────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── LiteLLM proxy authentication ──────────────────────────────────────────
# All API clients must send: Authorization: Bearer <LITELLM_MASTER_KEY>
# For Claude Code / Codex: set ANTHROPIC_API_KEY or OPENAI_API_KEY to this value
# and point the base URL at http://localhost:4000
LITELLM_MASTER_KEY=

# ── Web UI / Admin secrets ─────────────────────────────────────────────────
JWT_SECRET=
ADMIN_PASSWORD=

# ── Cloud fallbacks (disabled by default) ─────────────────────────────────
# Set ENABLE_CLOUD=true to allow fallback to cloud models when local fails.
# Also uncomment the relevant model entries in config/litellm/config.yaml.
ENABLE_CLOUD=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

