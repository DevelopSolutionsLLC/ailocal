# Environment and generated secrets — never commit
.env
.env.local
*.env.local

# Active model profile — machine-specific, generated by install.sh from
# config/profiles/<tier>.yaml based on detected RAM. The profiles/ are the
# committed source of truth; this is just the selected copy (like .env).
config/models.yaml

# Data, logs, and backups — contain runtime state and may contain secrets
/data/
/logs/
/backups/

# Backup archives (defence in depth — /backups/ above already covers the directory)
*.tar.gz
*.tar.bz2

# Key and certificate files — should never be committed
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# macOS
.DS_Store
*.swp
*.swo
*~

# IDEs and AI coding tools
.vscode/
.idea/
*.iml
.claude/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
